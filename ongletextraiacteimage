import { CONFIG_GET_EXTRAIT_ACTE_IMAGE } from "@api/configurations/etatCivil/acte/GetExtraitActeImageConfigApi";
import OngletsContenu from "@composants/commun/onglets/OngletsContenu";
import React, { useContext, useEffect, useState } from "react";
import { FiFileText } from "react-icons/fi";
import { EditionMiseAJourContext } from "../../../../contexts/EditionMiseAJourContextProvider";
import useFetchApi from "../../../../hooks/api/FetchApiHook";
import AfficherMessage from "../../../../utils/AfficherMessage";

interface IOngletExtraitActeImageProps {
  estActif: boolean;
}

const OngletExtraitActeImage: React.FC<IOngletExtraitActeImageProps> = ({ estActif }) => {
  const { idActe } = useContext(EditionMiseAJourContext.Valeurs);
  const [texteExtrait, setTexteExtrait] = useState<string | null>(null);

  const { appelApi: getExtraitActeImage } = useFetchApi(CONFIG_GET_EXTRAIT_ACTE_IMAGE);

  useEffect(() => {
    if (!estActif || texteExtrait !== null) return;

    getExtraitActeImage({
      parametres: { path: { idActe } },
      apresSucces: reponse => setTexteExtrait(reponse.texte),
      apresErreur: erreurs =>
        AfficherMessage.erreur("Une erreur est survenue lors de la récupération de l'extrait de l'acte image.", { erreurs })
    });
  }, [estActif, idActe]);

  return (
    <OngletsContenu estActif={estActif}>
      <div className="flex h-[calc(100vh-16rem)] flex-col">
        <div className="flex-1 overflow-hidden bg-gray-50">
          <div className="h-full w-full overflow-y-auto py-8">
            <div className="mx-auto min-h-[842px] w-[630px] bg-white px-12 py-16 shadow-lg">
              {texteExtrait ? (
                <pre className="w-full whitespace-pre-wrap text-justify font-mono text-sm leading-relaxed text-gray-900">
                  {texteExtrait}
                </pre>
              ) : (
                <div className="flex h-full items-center justify-center">
                  <div className="text-center text-gray-400">
                    <FiFileText className="mx-auto mb-3 h-12 w-12" />
                    <p className="text-sm">Aucun extrait disponible</p>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </OngletsContenu>
  );
};

export default OngletExtraitActeImage;
