package fr.gouv.diplomatie.rece.composition.util;

import fr.gouv.diplomatie.rece.commun.exceptions.TechnicalException;
import fr.gouv.diplomatie.rece.composition.erreurs.TechCodeErreur;
import lombok.experimental.UtilityClass;

import javax.imageio.ImageIO;
import java.awt.Graphics2D;
import java.awt.image.BufferedImage;
import java.io.ByteArrayInputStream;
import java.io.ByteArrayOutputStream;
import java.io.IOException;
import java.util.Base64;

@UtilityClass
public final class OrientationActeImageUtil {

	private static final String FORMAT_SORTIE = "png";

	/**
	 * Si l'image encodée en base64 est en paysage (largeur > hauteur), la fait pivoter de -90°
	 * afin d'obtenir une image portrait. Si l'image est déjà portrait (ou carrée), la chaîne
	 * d'origine est renvoyée telle quelle (pas de ré-encodage, pas de perte de qualité).
	 */
	public static String pivoterSiPaysage(String imageBase64) {
		BufferedImage imageSource;
		try {
			byte[] octetsImage = Base64.getDecoder().decode(imageBase64);
			imageSource = ImageIO.read(new ByteArrayInputStream(octetsImage));
		} catch (IOException exception) {
			throw new TechnicalException(TechCodeErreur.ERREUR_ANALYSE_JSON, exception);
		}
		if (imageSource == null) {
			throw new TechnicalException(TechCodeErreur.ERREUR_ANALYSE_JSON,
					new IllegalStateException("Image de l'acte illisible"));
		}

		int largeur = imageSource.getWidth();
		int hauteur = imageSource.getHeight();
		if (largeur <= hauteur) {
			return imageBase64;
		}

		BufferedImage imagePivotee = new BufferedImage(hauteur, largeur, BufferedImage.TYPE_INT_ARGB);
		Graphics2D dessin = imagePivotee.createGraphics();
		try {
			dessin.translate(0, largeur);
			dessin.rotate(-Math.PI / 2);
			dessin.drawImage(imageSource, 0, 0, null);
		} finally {
			dessin.dispose();
		}

		try {
			ByteArrayOutputStream fluxSortie = new ByteArrayOutputStream();
			ImageIO.write(imagePivotee, FORMAT_SORTIE, fluxSortie);
			return Base64.getEncoder().encodeToString(fluxSortie.toByteArray());
		} catch (IOException exception) {
			throw new TechnicalException(TechCodeErreur.ERREUR_ANALYSE_JSON, exception);
		}
	}
}
