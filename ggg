import { CONFIG_GET_EXTRAIT_ACTE_IMAGE } from "@api/configurations/etatCivil/acte/GetExtraitActeImageConfig";
import { CONFIG_GET_RESUME_ACTE } from "@api/configurations/etatCivil/acte/GetResumeActeConfigApi";
import { MockApi } from "@mock/appelsApi/MockApi";
import MockRECEContextProvider from "@mock/context/MockRECEContextProvider";
import MockUtilisateurBuilder from "@mock/model/agent/MockUtilisateur";
import { MockFicheActeBuilder } from "@mock/model/etatcivil/acte/MockFicheActe";
import { URL_ACCUEIL } from "@router/infoPages/InfoPagesBase";
import { render, screen, waitFor } from "@testing-library/react";
import React, { useContext } from "react";
import { afterEach, describe, expect, test, vi } from "vitest";
import EditionMiseAJourContextProvider, { EditionMiseAJourContext } from "../../contexts/EditionMiseAJourContextProvider";

const mockedNavigate = vi.fn();

vi.mock("react-router", async () => {
  const actual = await vi.importActual<typeof import("react-router")>("react-router");
  return { ...actual, useNavigate: () => mockedNavigate };
});

const lancerTraitementAbandonnerMock = vi.fn((appel?: { finalement?: () => void }) => appel?.finalement?.());

vi.mock("../../hooks/api/TraitementApiHook", () => ({
  default: () => ({
    lancerTraitement: lancerTraitementAbandonnerMock,
    traitementEnCours: false
  })
}));

vi.mock("../../hooks/CreateBlocker", () => ({
  useCreateBlocker: () => ({
    gestionBlocker: {
      activerBlockerSansConfirmation: vi.fn(),
      activerBlockerAvecConfirmation: vi.fn(),
      desactiverBlocker: vi.fn()
    },
    BlockerNavigation: () => null
  })
}));

vi.mock("../../composants/pages/requetesMiseAJour/compteurTemps/CompteurTemps", () => ({
  default: () => null
}));

vi.mock("../../composants/commun/chargeurs/PageChargeur", () => ({
  default: () => null
}));

const verifierDroitsMiseAJourActeMock = vi.fn();
const estActeEligibleDoubleNumeriqueMock = vi.fn();

vi.mock("../../composants/pages/requetesMiseAJour/droitsMiseAJourUtils", () => ({
  verifierDroitsMiseAJourActe: (...args: unknown[]) => verifierDroitsMiseAJourActeMock(...args),
  estActeEligibleDoubleNumerique: (...args: unknown[]) => estActeEligibleDoubleNumeriqueMock(...args)
}));

vi.mock("../../utils/AfficherMessage", () => ({
  default: { erreur: vi.fn() }
}));

const ComposantDeTest: React.FC = () => {
  const { typeActe, extraitActeImage, estEligibleDoubleNumerique } = useContext(EditionMiseAJourContext.Valeurs);
  return (
    <div>
      <div data-testid="typeActe">{typeActe ?? "null"}</div>
      <div data-testid="eligible">{String(estEligibleDoubleNumerique)}</div>
      <div data-testid="extrait">{extraitActeImage ?? "null"}</div>
    </div>
  );
};

describe("EditionMiseAJourContextProvider", () => {
  afterEach(() => {
    MockApi.stopMock();
    vi.clearAllMocks();
  });

  test("redirige à l'accueil si la vérification des droits (resume acte) échoue", async () => {
    MockApi.deployer(CONFIG_GET_RESUME_ACTE, { path: { idActe: "idActe" }, query: { remplaceIdentiteTitulaireParIdentiteTitulaireAM: true } }, { codeHttp: 500 });

    render(
      <MockRECEContextProvider utilisateurConnecte={MockUtilisateurBuilder.utilisateurConnecte().generer()}>
        <EditionMiseAJourContextProvider idActe="idActe" idRequete="idRequete" estMiseAJourAvecMentions={false}>
          <ComposantDeTest />
        </EditionMiseAJourContextProvider>
      </MockRECEContextProvider>
    );

    await waitFor(() => {
      expect(lancerTraitementAbandonnerMock).toHaveBeenCalled();
      expect(mockedNavigate).toHaveBeenCalledWith(URL_ACCUEIL, { replace: true });
    });
  });

  test("redirige à l'accueil si l'utilisateur n'est pas autorisé", async () => {
    verifierDroitsMiseAJourActeMock.mockReturnValue({
      autorise: false,
      peutMettreAJourMentions: false,
      peutMettreAJourAnalyseMarginale: false
    });
    estActeEligibleDoubleNumeriqueMock.mockReturnValue(false);

    MockApi.deployer(
      CONFIG_GET_RESUME_ACTE,
      { path: { idActe: "idActe" }, query: { remplaceIdentiteTitulaireParIdentiteTitulaireAM: true } },
      { data: new MockFicheActeBuilder().deType("IMAGE").genererDto() }
    );

    render(
      <MockRECEContextProvider utilisateurConnecte={MockUtilisateurBuilder.utilisateurConnecte().generer()}>
        <EditionMiseAJourContextProvider idActe="idActe" idRequete="idRequete" estMiseAJourAvecMentions={false}>
          <ComposantDeTest />
        </EditionMiseAJourContextProvider>
      </MockRECEContextProvider>
    );

    await waitFor(() => {
      expect(lancerTraitementAbandonnerMock).toHaveBeenCalled();
      expect(mockedNavigate).toHaveBeenCalledWith(URL_ACCUEIL, { replace: true });
    });
  });

  test("renseigne typeActe, eligibleDoubleNumerique et extraitActeImage quand tout se passe bien", async () => {
    verifierDroitsMiseAJourActeMock.mockReturnValue({
      autorise: true,
      peutMettreAJourMentions: true,
      peutMettreAJourAnalyseMarginale: true
    });
    estActeEligibleDoubleNumeriqueMock.mockReturnValue(true);

    MockApi.deployer(
      CONFIG_GET_RESUME_ACTE,
      { path: { idActe: "idActe" }, query: { remplaceIdentiteTitulaireParIdentiteTitulaireAM: true } },
      { data: new MockFicheActeBuilder().deType("IMAGE").genererDto() }
    );
    MockApi.deployer(CONFIG_GET_EXTRAIT_ACTE_IMAGE, { path: { idActe: "idActe" } }, { data: [{ extrait: "EXTRAIT_OK" }] });

    render(
      <MockRECEContextProvider utilisateurConnecte={MockUtilisateurBuilder.utilisateurConnecte().generer()}>
        <EditionMiseAJourContextProvider idActe="idActe" idRequete="idRequete" estMiseAJourAvecMentions={false}>
          <ComposantDeTest />
        </EditionMiseAJourContextProvider>
      </MockRECEContextProvider>
    );

    await waitFor(() => expect(screen.getByTestId("typeActe").textContent).toBe("IMAGE"));
    await waitFor(() => expect(screen.getByTestId("eligible").textContent).toBe("true"));
    await waitFor(() => expect(screen.getByTestId("extrait").textContent).toBe("EXTRAIT_OK"));
  });

  test("met extraitActeImage à null si l'appel d'extrait échoue", async () => {
    verifierDroitsMiseAJourActeMock.mockReturnValue({
      autorise: true,
      peutMettreAJourMentions: true,
      peutMettreAJourAnalyseMarginale: true
    });
    estActeEligibleDoubleNumeriqueMock.mockReturnValue(true);

    MockApi.deployer(
      CONFIG_GET_RESUME_ACTE,
      { path: { idActe: "idActe" }, query: { remplaceIdentiteTitulaireParIdentiteTitulaireAM: true } },
      { data: new MockFicheActeBuilder().deType("IMAGE").genererDto() }
    );
    MockApi.deployer(CONFIG_GET_EXTRAIT_ACTE_IMAGE, { path: { idActe: "idActe" } }, { codeHttp: 500 });

    render(
      <MockRECEContextProvider utilisateurConnecte={MockUtilisateurBuilder.utilisateurConnecte().generer()}>
        <EditionMiseAJourContextProvider idActe="idActe" idRequete="idRequete" estMiseAJourAvecMentions={false}>
          <ComposantDeTest />
        </EditionMiseAJourContextProvider>
      </MockRECEContextProvider>
    );

    await waitFor(() => expect(screen.getByTestId("typeActe").textContent).toBe("IMAGE"));
    await waitFor(() => expect(screen.getByTestId("extrait").textContent).toBe("null"));
  });
});

