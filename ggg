describe("VerificationDonnees", () => {
  const mockSetVerificationDonneesEffectuee = vi.fn();
  const mockChangerOnglet = vi.fn();
  const mockSetEstActeSigne = vi.fn();
  const mockDesactiverBlocker = vi.fn();

  const defaultProps = {
    miseAJourEffectuee: true,
    verificationDonneesEffectuee: false,
    setVerificationDonneesEffectuee: mockSetVerificationDonneesEffectuee,
    saisieMentionEnCours: false,
    verificationObligatoire: true
  };

  const renderComp = (acte: any, propsOverride = {}, droits: Droit[] = [Droit.SIGNER_MENTION, Droit.METTRE_A_JOUR_ACTE]) =>
    render(
      <MockRECEContextProvider utilisateurConnecte={MockUtilisateurBuilder.utilisateurConnecte().avecDroits(droits).generer()}>
        <EditionMiseAJourContext.Valeurs.Provider
          value={
            {
              idActe: "1010",
              idRequete: "req-001",
              miseAJourEffectuee: true,
              estMiseAJourAvecMentions: true,
              ongletsActifs: { actes: ECleOngletsMiseAJour.ACTE, formulaires: ECleOngletsMiseAJour.VERIFICATION_DONNEES }
            } as IEditionMiseAJourContext
          }
        >
          <EditionMiseAJourContext.Actions.Provider
            value={{
              changerOnglet: mockChangerOnglet,
              setEstActeSigne: mockSetEstActeSigne,
              desactiverBlocker: mockDesactiverBlocker,
              activerOngletActeMisAJour: vi.fn(),
              setComposerActeMisAJour: vi.fn()
            }}
          >
            <VerificationDonnees
              acte={acte}
              {...defaultProps}
              {...propsOverride}
            />
          </EditionMiseAJourContext.Actions.Provider>
        </EditionMiseAJourContext.Valeurs.Provider>
      </MockRECEContextProvider>
    );

  afterEach(() => {
    MockApi.stopMock();
    vi.clearAllMocks();
  });

  test("affiche les champs NAISSANCE", () => {
    const { container } = renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer());
    expect(container).toMatchSnapshot();
  });

  test("affiche les champs MARIAGE", () => {
    const { container } = renderComp(new MockFicheActeBuilder().deNature("MARIAGE").generer());
    expect(container).toMatchSnapshot();
  });

  test("affiche les champs DECES", () => {
    const { container } = renderComp(new MockFicheActeBuilder().deNature("DECES").generer());
    expect(container).toMatchSnapshot();
  });

  test("nature inconnue - ne rend aucun champ specifique", () => {
    const { container } = renderComp(new MockFicheActeBuilder().deNature("INCONNUE" as any).generer());
    expect(container).toMatchSnapshot();
  });

  test("bouton desactive quand saisieMentionEnCours=true", () => {
    renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), { saisieMentionEnCours: true });
    expect(screen.getByRole("button", { name: /Terminer et signer/i })).toHaveProperty("disabled", true);
  });

  test("bouton desactive quand miseAJourEffectuee=false", () => {
    renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), { miseAJourEffectuee: false });
    expect(screen.getByRole("button", { name: /Terminer et signer/i })).toHaveProperty("disabled", true);
  });

  test("bouton desactive quand verificationObligatoire=true et verificationDonneesEffectuee=false", () => {
    renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), {
      verificationObligatoire: true,
      verificationDonneesEffectuee: false
    });
    expect(screen.getByRole("button", { name: /Terminer et signer/i })).toHaveProperty("disabled", true);
  });

  test("bouton active quand toutes les conditions sont remplies", () => {
    renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), { verificationDonneesEffectuee: true });
    expect(screen.getByRole("button", { name: /Terminer et signer/i })).toHaveProperty("disabled", false);
  });

  test("bouton masque sans droit SIGNER_MENTION", () => {
    renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), {}, [Droit.METTRE_A_JOUR_ACTE]);
    expect(screen.queryByRole("button", { name: /Terminer et signer/i })).toBeNull();
  });

  test("bouton masque sans droit METTRE_A_JOUR_ACTE", () => {
    renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), {}, [Droit.SIGNER_MENTION]);
    expect(screen.queryByRole("button", { name: /Terminer et signer/i })).toBeNull();
  });

  test("soumission pour NAISSANCE double numerique ouvre la modale sans envoyer le PATCH immédiatement", async () => {
    renderComp(new MockFicheActeBuilder().deType("TEXTE").deNature("NAISSANCE").generer(), { verificationDonneesEffectuee: true });

    await act(async () => {
      fireEvent.click(screen.getByRole("button", { name: /Terminer et signer/i }));
    });
    // La rectification PATCH est différée dans avantSignature — aucun appel API à ce stade
    await waitFor(() => {
      expect(MockApi.getMock().history.patch.length).toBe(0);
    });
  });

  test("soumission pour MARIAGE double numerique ouvre la modale sans envoyer le PATCH immédiatement", async () => {
    renderComp(new MockFicheActeBuilder().deType("TEXTE").deNature("MARIAGE").generer(), { verificationDonneesEffectuee: true });
    await act(async () => {
      fireEvent.click(screen.getByRole("button", { name: /Terminer et signer/i }));
    });
    await waitFor(() => {
      expect(MockApi.getMock().history.patch.length).toBe(0);
    });
  });

  test("soumission pour DECES double numerique ouvre la modale sans envoyer le PATCH immédiatement", async () => {
    renderComp(new MockFicheActeBuilder().deType("TEXTE").deNature("DECES").generer(), { verificationDonneesEffectuee: true });
    await act(async () => {
      fireEvent.click(screen.getByRole("button", { name: /Terminer et signer/i }));
    });
    await waitFor(() => {
      expect(MockApi.getMock().history.patch.length).toBe(0);
    });
  });

  test("nature inconnue double numerique ne ouvre pas modale", async () => {
    const acte = new MockFicheActeBuilder().deType("TEXTE").deNature("INCONNUE").generer();
    renderComp(acte, { verificationDonneesEffectuee: true });
    const btn = screen.queryByRole("button", { name: /Terminer et signer/i });
    if (btn) {
      await act(async () => {
        fireEvent.click(btn);
      });
      await waitFor(() => {
        expect(screen.queryByText("Signature des mentions")).toBeNull();
      });
    }
  });

  test("snapshot avec miseAJourEffectuee=false", () => {
    const { container } = renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), { miseAJourEffectuee: false });
    expect(container).toMatchSnapshot();
  });

  test("snapshot avec verificationDonneesEffectuee=true", () => {
    const { container } = renderComp(new MockFicheActeBuilder().deNature("NAISSANCE").generer(), { verificationDonneesEffectuee: true });
    expect(container).toMatchSnapshot();
  });
});
