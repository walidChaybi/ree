import { compositionApi } from "@api/appels/compositionApi";
import {
  CONFIG_GET_DONNEES_POUR_COMPOSITION_ACTE_TEXTE_MIS_A_JOUR,
  IDonneesCompositionActe
} from "@api/configurations/etatCivil/acte/GetDonneesPourCompositionActeTexteMisAJourConfigApi";
import { CONFIG_GET_IMAGES_ACTE_FORMAT_TIFF } from "@api/configurations/etatCivil/acte/GetImagesActeFormatTiffConfigApi";
import AffichageDocument from "@composants/commun/affichageDocument/AffichageDocument";
import OngletsContenu from "@composants/commun/onglets/OngletsContenu";
import { IImage } from "@model/etatcivil/acte/imageActe/IImage";
import React, { useContext, useEffect, useState } from "react";
import { FiEye, FiFileText, FiType } from "react-icons/fi";
import { EditionMiseAJourContext } from "../../../../contexts/EditionMiseAJourContextProvider";
import useFetchApi from "../../../../hooks/api/FetchApiHook";
import { EMimeType } from "../../../../ressources/EMimeType";
import AfficherMessage from "../../../../utils/AfficherMessage";
import { nettoyerTexteSelectionne } from "../../../../utils/SelectionTexteUtils";

interface IPropsOngletActeMisAJour {
  estActif: boolean;
}

type ModeAffichage = "pdf" | "texte";

const OngletActeMisAJour: React.FC<IPropsOngletActeMisAJour> = ({ estActif }) => {
  const { idActe, composerActeMisAJour, estEligibleDoubleNumerique, estActeSigne, typeActe } = useContext(
    EditionMiseAJourContext.Valeurs
  );
  const { setComposerActeMisAJour, extraireTexte } = useContext(EditionMiseAJourContext.Actions);

  const [contenuPdf, setContenuPdf] = useState<string | null>(null);
  const [donneesTextuelles, setDonneesTextuelles] = useState<IDonneesCompositionActe | null>(null);
  const [modeAffichage, setModeAffichage] = useState<ModeAffichage>("pdf");

  const { appelApi: recupererDonneesComposition } = useFetchApi(CONFIG_GET_DONNEES_POUR_COMPOSITION_ACTE_TEXTE_MIS_A_JOUR);
  const { appelApi: recupererImagesTiff } = useFetchApi(CONFIG_GET_IMAGES_ACTE_FORMAT_TIFF);

  const composerActeImageDoubleNumerique = () => {
    recupererImagesTiff({
      parametres: { path: { idActe } },
      apresSucces: (images: IImage[]) => {
        recupererDonneesComposition({
          parametres: { path: { idActe } },
          apresSucces: reponse => {
            const donnees: IDonneesCompositionActe = JSON.parse(reponse);

            const corpsImage = images.toSorted((a, b) => a.noPage - b.noPage).map(image => image.contenu);

            compositionApi
              .getCompositionActeImageDoubleNumerique({
                corpsImage,
                referenceRece: donnees.reference_acte ?? "",
                referenceRegistre: donnees.reference_registre_papier ?? "",
                mentions: donnees.mentions ?? ""
              })
              .then(reponse => {
                setContenuPdf(reponse.body.data.contenu ?? "");
                setComposerActeMisAJour(false);
              })
              .catch(() => {
                AfficherMessage.erreur("Impossible de générer le document PDF");
              });
          },
          apresErreur: erreurs => AfficherMessage.erreur("Impossible de récupérer les données de l'acte", { erreurs })
        });
      },
      apresErreur: erreurs => AfficherMessage.erreur("Impossible de récupérer les images de l'acte", { erreurs })
    });
  };

  const composerActeTexte = () => {
    recupererDonneesComposition({
      parametres: { path: { idActe } },
      apresSucces: reponse => {
        const donnees: IDonneesCompositionActe = JSON.parse(reponse);

        compositionApi
          .getCompositionActeTexte(donnees)
          .then(reponse => {
            setContenuPdf(reponse.body.data.contenu ?? "");
            setComposerActeMisAJour(false);
          })
          .catch(() => {
            AfficherMessage.erreur("Impossible de générer le document PDF");
          });

        setDonneesTextuelles(donnees);
      },
      apresErreur: erreurs => AfficherMessage.erreur("Impossible de récupérer les données de l'acte", { erreurs })
    });
  };

  useEffect(() => {
    if (!composerActeMisAJour) return;

    if (typeActe === "IMAGE" && estEligibleDoubleNumerique) {
      composerActeImageDoubleNumerique();
    } else {
      composerActeTexte();
    }
  }, [composerActeMisAJour, idActe]);

  const gererSelectionTexte = () => {
    if (modeAffichage !== "texte" || !extraireTexte) return;

    const selection = window.getSelection();
    const texteSelectionne = selection?.toString();

    if (!texteSelectionne) return;

    const texteNettoye = nettoyerTexteSelectionne(texteSelectionne);
    if (texteNettoye.length > 0) {
      extraireTexte(texteNettoye);
      selection?.removeAllRanges();
    }
  };

  return (
    <OngletsContenu estActif={estActif}>
      <div className="flex h-[calc(100vh-16rem)] flex-col">
        {estEligibleDoubleNumerique && !estActeSigne && (
          <div className="flex items-center justify-end">
            <button
              onClick={() => setModeAffichage("pdf")}
              className={`flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium transition-colors ${
                modeAffichage === "pdf" ? "bg-bleu-sombre text-white" : "bg-gris-clair text-gris-sombre hover:bg-gray-200"
              }`}
              aria-label="Afficher en PDF"
            >
              <FiEye className="h-4 w-4" />
              PDF
            </button>

            <button
              onClick={() => setModeAffichage("texte")}
              className={`flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium transition-colors ${
                modeAffichage === "texte" ? "bg-bleu-sombre text-white" : "bg-gris-clair text-gris-sombre hover:bg-gray-200"
              }`}
              aria-label="Afficher en texte"
            >
              <FiType className="h-4 w-4" />
              Texte
            </button>
          </div>
        )}

        <div className="flex-1 overflow-hidden bg-gray-50">
          {modeAffichage === "pdf" || !estEligibleDoubleNumerique || estActeSigne ? (
            <AffichageDocument
              contenuBase64={contenuPdf}
              typeZoom={90}
              typeMime={EMimeType.APPLI_PDF}
            />
          ) : (
            <div className="h-full w-full overflow-y-auto py-8">
              <div
                className="mx-auto min-h-[842px] w-[630px] bg-white px-12 py-16 shadow-lg"
                onMouseUp={gererSelectionTexte}
              >
                {donneesTextuelles?.texte_corps_acte ? (
                  <pre className="w-full whitespace-pre-wrap text-justify font-mono text-sm leading-relaxed text-gray-900">
                    {donneesTextuelles.texte_corps_acte}
                  </pre>
                ) : (
                  <div className="flex h-full items-center justify-center">
                    <div className="text-center text-gray-400">
                      <FiFileText className="mx-auto mb-3 h-12 w-12" />
                      <p className="text-sm">Aucune donnée textuelle disponible</p>
                    </div>
                  </div>
                )}
              </div>
            </div>
          )}
        </div>
      </div>
    </OngletsContenu>
  );
};

export default OngletActeMisAJour;
