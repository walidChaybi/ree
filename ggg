import { CONFIG_POST_COMPOSITION_ACTE_TEXTE } from "@api/configurations/composition/PostCompositionActeTexteApiConfigApi";
import { CONFIG_GET_CORPS_ACTE_IMAGE } from "@api/configurations/etatCivil/acte/GetCorpsActeImage";
import { CONFIG_GET_RECOMPOSER_DOCUMENT_FINAL } from "@api/configurations/etatCivil/acte/GetRecomposerDocumentFinalConfigApi";
import { CONFIG_GET_DONNEES_POUR_COMPOSITION_ACTE_REPRIS } from "@api/configurations/etatCivil/acte/GetDonneesPourCompositionActeReprisConfigApi";
import {
  CONFIG_GET_DONNEES_POUR_COMPOSITION_ACTE_TEXTE_MIS_A_JOUR,
  IDonneesCompositionActeIn
} from "@api/configurations/etatCivil/acte/GetDonneesPourCompositionActeTexteMisAJourConfigApi";
import { ETypeActe } from "@model/etatcivil/enum/ETypeActe";
import React, { useEffect, useState } from "react";
import AffichageDocument from "../../../../composants/commun/affichageDocument/AffichageDocument";
import Bouton from "../../../../composants/commun/bouton/Bouton";
import useFetchApi from "../../../../hooks/api/FetchApiHook";
import { EMimeType } from "../../../../ressources/EMimeType";
import AfficherMessage from "../../../../utils/AfficherMessage";

const estActeImageAvecReferenceRece = (typeActe?: keyof typeof ETypeActe, numeroActeElectronique?: string | null) =>
  typeActe === ETypeActe.IMAGE && Boolean(numeroActeElectronique?.trim());

interface IVisionneuseActeProps {
  idActe?: string;
  typeActe?: keyof typeof ETypeActe;
  estReecrit?: boolean;
  /** Acte image signé en double numérique (réf. RECE) : afficher le PDF recomposé plutôt que le corps-image brut. */
  numeroActeElectronique?: string | null;
}

const VisionneuseActe: React.FC<IVisionneuseActeProps> = ({ idActe, typeActe, estReecrit, numeroActeElectronique }) => {
  const [contenuTexteBase64, setContenuTexteBase64] = useState<string | null>(null);
  const [contenuImageBase64, setContenuImageBase64] = useState<string | null>(null);
  const [contenuImageBlob, setContenuImageBlob] = useState<Blob | null>(null);
  const [estImage, setEstImage] = useState(typeActe === ETypeActe.IMAGE);

  const [donneesPourCompositionActeTexte, setDonneesPourCompositionActeTexte] = useState<IDonneesCompositionActeIn | null>(null);
  const [donneesPourCompositionActeRepris, setDonneesPourCompositionActeRepris] = useState<string | null>(null);

  const { appelApi: postCompositionActeTexte } = useFetchApi(CONFIG_POST_COMPOSITION_ACTE_TEXTE);
  const { appelApi: recupererCorpsActeImage } = useFetchApi(CONFIG_GET_CORPS_ACTE_IMAGE);
  const { appelApi: recomposerDocumentFinal } = useFetchApi(CONFIG_GET_RECOMPOSER_DOCUMENT_FINAL);
  const { appelApi: recupererDonneesCompositionActeTexte } = useFetchApi(CONFIG_GET_DONNEES_POUR_COMPOSITION_ACTE_TEXTE_MIS_A_JOUR);
  const { appelApi: recupererDonneesPourCompositionActeRepris } = useFetchApi(CONFIG_GET_DONNEES_POUR_COMPOSITION_ACTE_REPRIS);

  useEffect(() => {
    if (!idActe) return;

    const afficherPdfComposeImage = estActeImageAvecReferenceRece(typeActe, numeroActeElectronique);

    switch (true) {
      case estImage:
        if (afficherPdfComposeImage) {
          if (!contenuImageBlob) {
            recomposerDocumentFinal({
              parametres: { path: { idActe } },
              apresSucces: pdf => {
                if (pdf.size === 0) {
                  AfficherMessage.erreur("La visualisation de l'acte n'est pas disponible");
                }
                setContenuImageBlob(pdf);
              },
              apresErreur: erreurs =>
                AfficherMessage.erreur("Impossible de récupérer l'acte recomposé", {
                  erreurs
                })
            });
          }
        } else if (!contenuImageBase64) {
          setContenuImageBlob(null);
          recupererCorpsActeImage({
            parametres: { path: { idActe } },
            apresSucces: corpsActeImage => setContenuImageBase64(corpsActeImage.contenu),
            apresErreur: erreurs =>
              AfficherMessage.erreur("Une erreur est survenue lors de la récupération de l'acte image.", {
                erreurs
              })
          });
        }
        break;

      case estReecrit:
        !donneesPourCompositionActeRepris &&
          recupererDonneesPourCompositionActeRepris({
            parametres: { path: { idActe } },
            apresSucces: setDonneesPourCompositionActeRepris,
            apresErreur: erreurs =>
              AfficherMessage.erreur("Une erreur est survenue lors de la récupération de l'acte texte.", {
                erreurs
              })
          });
        break;

      default:
        !donneesPourCompositionActeTexte &&
          recupererDonneesCompositionActeTexte({
            parametres: { path: { idActe } },
            apresSucces: setDonneesPourCompositionActeTexte,
            apresErreur: erreurs =>
              AfficherMessage.erreur("Une erreur est survenue lors de la récupération de l'acte texte.", {
                erreurs
              })
          });
        break;
    }
  }, [idActe, estImage, estReecrit, typeActe, numeroActeElectronique]);

  useEffect(() => {
    if (!donneesPourCompositionActeTexte) return;

    postCompositionActeTexte({
      parametres: {
        body: {
          nature_acte: donneesPourCompositionActeTexte.natureActe,
          texte_corps_acte: donneesPourCompositionActeTexte.texteCorpsActe,
          mentions: donneesPourCompositionActeTexte.mentions,
          titulaires: donneesPourCompositionActeTexte.titulaires,
          reference_acte: donneesPourCompositionActeTexte.referenceActe,
          reference_registre_papier: donneesPourCompositionActeTexte.referenceRegistrePapier
        }
      },
      apresSucces: reponse => setContenuTexteBase64(reponse.contenu),
      apresErreur: erreurs => AfficherMessage.erreur("Impossible d'obtenir les informations de l'acte", { erreurs })
    });
  }, [donneesPourCompositionActeTexte]);

  const onClickSwitchActeExtraitRepris = () => {
    setEstImage(prec => !prec);
  };

  const afficherPdfComposeImage = estActeImageAvecReferenceRece(typeActe, numeroActeElectronique);
  const documentImageComposePret = estImage && afficherPdfComposeImage && contenuImageBlob;
  const documentImageBrutPret = estImage && !afficherPdfComposeImage && contenuImageBase64;
  const documentTextePret = !estImage && contenuTexteBase64;

  return (
    <>
      {estReecrit && (
        <Bouton
          className="float-right"
          onClick={onClickSwitchActeExtraitRepris}
          styleBouton="principal"
        >
          {estImage ? "Voir extrait repris" : "Voir acte"}
        </Bouton>
      )}
      {(documentImageComposePret || documentImageBrutPret || documentTextePret) && (
        <AffichageDocument
          contenuBlob={documentImageComposePret ? contenuImageBlob! : undefined}
          contenuBase64={
            documentTextePret ? contenuTexteBase64! : documentImageBrutPret ? contenuImageBase64! : undefined
          }
          typeZoom={documentImageComposePret ? "page-fit" : documentImageBrutPret ? "auto" : 90}
          typeMime={EMimeType.APPLI_PDF}
        />
      )}
    </>
  );
};

export default VisionneuseActe;
