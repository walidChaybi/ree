import { CONFIG_GET_UTILISATEUR_CONNECTE } from "@api/configuration/agent/utilisateurs/GetUtilisateurConnecteConfigApi";
import PageChargeur from "@composants/commun/PageChargeur/PageChargeur";
import useFetchApi from "@hooks/api/FetchApiHook";
import { URL_DECONNEXION } from "@router/AppRouterUrls";
import ErreurRouter from "@router/ErreurRouter";
import { ZERO } from "@util/NombresMagiques";
import { StockageLocal } from "@util/StockageLocal";
import { getText } from "@util/TextUtils";
import ToastMessage from "@util/ToastMessage";
import React, { createContext, useCallback, useEffect, useMemo, useState } from "react";
import { UtilisateurConnecte } from "../model/agent/UtilisateurConnecte";
import { gestionnaireFeatureFlag } from "@util/featureFlag/gestionnaireFeatureFlag";

interface IUtilisateurConnecteContext {
  utilisateurConnecte: UtilisateurConnecte;
  seDeconnecter: () => void;
}

const UtilisateurConnecteContext = createContext<IUtilisateurConnecteContext>({} as IUtilisateurConnecteContext);

const UtilisateurConnecteContextProvider: React.FC<React.PropsWithChildren> = ({ children }) => {
  useEffect(() => {
    StockageLocal.insererIdentiteUtilisateurConnecteDepuisUrl();
  }, []);

  const [utilisateurConnecte, setUtilisateurConnecte] = useState<UtilisateurConnecte | null>(null);
  const [estVerifie, setEstVerifie] = useState<boolean>(false);
  const [messageErreur, setMessageErreur] = useState<string>("");
  const seDeconnecter = useCallback<() => void>(() => {
    setUtilisateurConnecte(null);
    setMessageErreur(getText("pages.login.erreurDeconnecte"));
    window.location.replace(URL_DECONNEXION);
  }, []);
  const { appelApi: appelApiLogin } = useFetchApi(CONFIG_GET_UTILISATEUR_CONNECTE);

  useEffect(() => {
    if (estVerifie) {
      return;
    }

    appelApiLogin({
      apresSucces: (data, headers) => {
        const utilisateur = UtilisateurConnecte.depuisDto(data);
        if (utilisateur) {
          gestionnaireFeatureFlag.positionneFlagsAPartirDuHeader(headers, utilisateur.idArobas);
        }
        setUtilisateurConnecte(utilisateur);
      },
      apresErreur: erreurs => {
        const erreurCode = erreurs[ZERO]?.code;
        ToastMessage.erreur(getText("pages.login.erreurAuthentification"));
        setMessageErreur(getText(erreurCode ? `erreurFct.${erreurCode}` : "pages.login.erreurSysteme"));
      },
      finalement: () => setEstVerifie(true)
    });
  }, [estVerifie]);

  const valeurContexte: IUtilisateurConnecteContext = useMemo(
    () => ({ utilisateurConnecte: utilisateurConnecte || ({} as UtilisateurConnecte), seDeconnecter }),
    [utilisateurConnecte, seDeconnecter]
  );

  if (!estVerifie) return <PageChargeur />;

  return (
    <UtilisateurConnecteContext.Provider value={valeurContexte}>
      {utilisateurConnecte ? children : <ErreurRouter message={messageErreur} />}
    </UtilisateurConnecteContext.Provider>
  );
};

export { UtilisateurConnecteContext, UtilisateurConnecteContextProvider };
